# =============================================================================
# Vitar v11 — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in the values before running the app.
# Never commit .env to version control.
#
# List fields (ALLOWED_ORIGINS, ALLOWED_HOSTS) accept three formats:
#   JSON array:        ALLOWED_ORIGINS='["https://a.com","https://b.com"]'
#   Comma-separated:  ALLOWED_ORIGINS=https://a.com,https://b.com
#   Single value:     ALLOWED_ORIGINS=https://a.com
# =============================================================================

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=Vitar
# Options: development | staging | production
ENVIRONMENT=development
# Generate with: openssl rand -hex 32
SECRET_KEY=

DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose default — change password in production
DATABASE_URL=postgresql://vitar:vitar@postgres:5432/vitar
POSTGRES_PASSWORD=vitar
DATABASE_POOL_SIZE=15
DATABASE_MAX_OVERFLOW=25
# Hard per-query timeout (milliseconds)
DB_STATEMENT_TIMEOUT_MS=30000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30


# These should already be in your .env — confirm them:
MIGRATION_DATABASE_URL=postgresql://vitar:vitar@postgres:5432/vitar


# ── CORS / Hosts ──────────────────────────────────────────────────────────────
# Production: set to your real domain(s)
# Dev default includes localhost:5173 (Vite dev server) — fine for local use
# Fix 9: Set this to the exact Wabizz production domain(s). No wildcards.
# Do NOT add *.workers.dev — it covers all Cloudflare Workers, not just Wabizz.
# Production example:  ALLOWED_ORIGINS=["https://app.wabizz.com"]
# Local dev example:   ALLOWED_ORIGINS=["http://localhost:5173"]
ALLOWED_ORIGINS=["http://localhost","http://localhost:3002","http://localhost:5173","http://127.0.0.1:5173","https://livevault.cloud","https://www.livevault.cloud","https://app.livevault.cloud","https://api.livevault.cloud"]
ALLOWED_HOSTS=["localhost","127.0.0.1","livevault.cloud","www.livevault.cloud","app.livevault.cloud","api.livevault.cloud"]

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://livevault.cloud
VITE_API_URL=/api/v1
API_DOCS_ENABLED=true

# ── Payment (at least one required in production) ─────────────────────────────
PAYSTACK_SECRET_KEY= 
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=https://app.livevault.cloud/settings/billing
PAYSTACK_WEBHOOK_URL=https://api.livevault.cloud/api/v1/billing/webhook/paystack
PAYSTACK_BASE_URL=https://api.paystack.co

FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Notifications ─────────────────────────────────────────────────────────────
# At least one SMS provider recommended
TERMII_API_KEY=
TERMII_SENDER_ID=Vitar

TWILIO_ACCOUNT_SID=S
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+19784901237

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Required for transactional email (registration, password reset)
SENDGRID_API_KEY=
EMAIL_FROM=vitarhealthcare@gmail.com
EMAIL_FROM_NAME=Vitar Health

# ── AI / ML ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=
ML_MODEL_PATH=/app/ml_models

# ── Monitoring ────────────────────────────────────────────────────────────────
# Optional but strongly recommended in production
SENTRY_DSN=

# ── Geo / Currency ────────────────────────────────────────────────────────────
IPAPI_KEY=
EXCHANGE_RATE_API_KEY=

# ── Trial limits ──────────────────────────────────────────────────────────────
TRIAL_DAYS=14
TRIAL_MAX_BOOKINGS=50
TRIAL_MAX_DOCTORS=2

# ── Storage ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vitar-uploads
AWS_REGION=us-east-1
STORAGE_BACKEND=local
ALLOW_LOCAL_UPLOADS_IN_PRODUCTION=true
UPLOAD_DIR=/app/uploads

# ── Observability dashboards ──────────────────────────────────────────────────
# CHANGE these in production — defaults are rejected by startup validation
FLOWER_USER=admin
FLOWER_PASSWORD=
GRAFANA_USER=admin
GRAFANA_PASSWORD=
SLOW_QUERY_THRESHOLD_S=0.5


OWNER_BANK_NAME=Provius Bank
OWNER_ACCOUNT_NUMBER=6501996574
OWNER_ACCOUNT_NAME=Emmanuel Chidera Nwobodo


OWNER_BANK_NAME_2=OPay
OWNER_ACCOUNT_NUMBER_2=7016479713
OWNER_ACCOUNT_NAME_2=Emmanuel Chidera Nwobodo

# ── Alerts ────────────────────────────────────────────────────────────────────
# Optional: Slack incoming webhook URL for ops alerts
SLACK_WEBHOOK_URL=
PROMETHEUS_URL=http://prometheus:9090

# ── System resource thresholds ────────────────────────────────────────────────
CPU_ALERT_THRESHOLD_PCT=85.0
CPU_CRITICAL_THRESHOLD_PCT=95.0
MEMORY_ALERT_THRESHOLD_PCT=80.0
MEMORY_CRITICAL_THRESHOLD_PCT=90.0
DISK_ALERT_THRESHOLD_PCT=80.0
DISK_CRITICAL_THRESHOLD_PCT=92.0
DISK_CHECK_PATH=/

# ── Background job safety ─────────────────────────────────────────────────────
TASK_STUCK_THRESHOLD_S=600
AUTOHEAL_STUCK_TASKS=false

# ── PgBouncer (optional connection pooler) ────────────────────────────────────
PGBOUNCER_ENABLED=false
PGBOUNCER_URL=postgresql://vitar:vitar@pgbouncer:5432/vitar

# ── Autoscaling (Docker Swarm / custom orchestration) ─────────────────────────
AUTOSCALE_ENABLED=false
AUTOSCALE_DRY_RUN=true
WORKER_MIN_REPLICAS=1
WORKER_MAX_REPLICAS=8
WORKER_SCALE_UP_QUEUE_DEPTH=100
WORKER_SCALE_DOWN_QUEUE_DEPTH=20
API_MIN_REPLICAS=1
API_MAX_REPLICAS=6
API_SCALE_UP_RPS=50.0
API_SCALE_DOWN_RPS=10.0

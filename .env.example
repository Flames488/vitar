# =============================================================================
# Vitar v11 — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in the values before running the app.
# Never commit .env to version control.
#
# List fields (ALLOWED_ORIGINS, ALLOWED_HOSTS) accept three formats:
#   JSON array:        ALLOWED_ORIGINS='["https://a.com","https://b.com"]'
#   Comma-separated:  ALLOWED_ORIGINS=https://a.com,https://b.com
#   Single value:     ALLOWED_ORIGINS=https://a.com
# =============================================================================

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=Vitar
# Options: development | staging | production
ENVIRONMENT=development
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-32-char-min
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# v12: Points to PgBouncer, not Postgres directly.
# PgBouncer (always-on) multiplexes app connections to 20 real PG connections,
# making 500-user scale safe. Do NOT change this back to postgres:5432.
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://vitar:change-me-strong-password@pgbouncer:5432/vitar
MIGRATION_DATABASE_URL=postgresql://vitar:change-me-strong-password@postgres:5432/vitar
# Per-worker pool size. With PgBouncer in front these can stay small.
# Single node: 4 workers × 40 = 160 client conns → PgBouncer → 20 PG conns
DATABASE_POOL_SIZE=15
DATABASE_MAX_OVERFLOW=25
# Hard per-query timeout (milliseconds)
DB_STATEMENT_TIMEOUT_MS=30000

# ── Redis ─────────────────────────────────────────────────────────────────────
# Single-node Redis (default — docker-compose.yml)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Redis HA via Sentinel (docker-compose.redis-ha.yml) ──────────────────────
# Use these URLs instead when running the Sentinel overlay.
# The app auto-detects the redis-sentinel:// scheme and connects via Sentinel.
# REDIS_URL=redis-sentinel://sentinel1:26379,sentinel2:26379,sentinel3:26379/mymaster/0
# CELERY_BROKER_URL=redis-sentinel://sentinel1:26379,sentinel2:26379,sentinel3:26379/mymaster/1
# CELERY_RESULT_BACKEND=redis-sentinel://sentinel1:26379,sentinel2:26379,sentinel3:26379/mymaster/2

# ── Upstash Redis (recommended managed option) ────────────────────────────────
# Sign up at https://upstash.com — free tier handles this load with HA built in.
# REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379
# CELERY_BROKER_URL=rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379
# CELERY_RESULT_BACKEND=rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=jwt-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS / Hosts ──────────────────────────────────────────────────────────────
# Production: set to your real domain(s)
# Dev default includes localhost:5173 (Vite dev server) — fine for local use
ALLOWED_ORIGINS=["https://labvault.cloud","http://localhost:5173","http://127.0.0.1:5173"]
ALLOWED_HOSTS=["localhost","127.0.0.1","labvault.cloud","www.labvault.cloud"]

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000/api/v1

# ── Payment (at least one required in production) ─────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_BASE_URL=https://api.paystack.co

FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Notifications ─────────────────────────────────────────────────────────────
# At least one SMS provider recommended
TERMII_API_KEY=
TERMII_SENDER_ID=Vitar

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Required for transactional email (registration, password reset)
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@labvault.cloud
EMAIL_FROM_NAME=Vitar Health

# ── AI / ML ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=
ML_MODEL_PATH=/app/ml_models

# ── Monitoring ────────────────────────────────────────────────────────────────
# Optional but strongly recommended in production
SENTRY_DSN=

# ── Geo / Currency ────────────────────────────────────────────────────────────
IPAPI_KEY=
EXCHANGE_RATE_API_KEY=

# ── Trial limits ──────────────────────────────────────────────────────────────
TRIAL_DAYS=14
TRIAL_MAX_BOOKINGS=50
TRIAL_MAX_DOCTORS=2

# ── Storage ───────────────────────────────────────────────────────────────────
# STORAGE_BACKEND: 's3' for production (multi-replica), 'local' for dev only.
#
# local → files written to UPLOAD_DIR on the container filesystem.
#         NOT safe for production: files lost on restart, invisible across replicas.
#
# s3    → files uploaded to AWS S3. All replicas share one bucket.
#         Required when running docker-compose.scale.yml (500-user mode).
#
STORAGE_BACKEND=local          # change to s3 in production

# Required when STORAGE_BACKEND=s3:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vitar-uploads
AWS_REGION=us-east-1

# Used by local backend only (ignored when using S3):
UPLOAD_DIR=/app/uploads

# ── Observability dashboards ──────────────────────────────────────────────────
# CHANGE these in production — defaults are rejected by startup validation
FLOWER_USER=admin
FLOWER_PASSWORD=vitar_flower
GRAFANA_USER=admin
GRAFANA_PASSWORD=vitar_grafana
SLOW_QUERY_THRESHOLD_S=0.5

# ── Alerts ────────────────────────────────────────────────────────────────────
# Optional: Slack incoming webhook URL for ops alerts
SLACK_WEBHOOK_URL=
PROMETHEUS_URL=http://prometheus:9090

# ── System resource thresholds ────────────────────────────────────────────────
CPU_ALERT_THRESHOLD_PCT=85.0
CPU_CRITICAL_THRESHOLD_PCT=95.0
MEMORY_ALERT_THRESHOLD_PCT=80.0
MEMORY_CRITICAL_THRESHOLD_PCT=90.0
DISK_ALERT_THRESHOLD_PCT=80.0
DISK_CRITICAL_THRESHOLD_PCT=92.0
DISK_CHECK_PATH=/

# ── Background job safety ─────────────────────────────────────────────────────
TASK_STUCK_THRESHOLD_S=600
AUTOHEAL_STUCK_TASKS=false
OPS_MONITORING_ENABLED=false

# ── PgBouncer (connection pooler — always-on in v12) ─────────────────────────
# v12: PgBouncer is always-on. Do not disable unless you understand the
# connection pool math (see docker-compose.yml comments).
PGBOUNCER_ENABLED=true
PGBOUNCER_URL=postgresql://vitar:change-me-strong-password@pgbouncer:5432/vitar

# ── Migration control ─────────────────────────────────────────────────────────
# SKIP_MIGRATIONS=false  → each API replica runs alembic on startup (safe for single node)
# SKIP_MIGRATIONS=true   → replicas skip migrations (set this in docker-compose.scale.yml)
#                           CI deploy.yml runs migrations once as a dedicated step
SKIP_MIGRATIONS=false

# ── Autoscaling (Docker Swarm / custom orchestration) ─────────────────────────
# v12: Autoscaler enabled. Set AUTOSCALE_DRY_RUN=true first to observe
# decisions without executing them, then flip to false when confident.
AUTOSCALE_ENABLED=true
AUTOSCALE_DRY_RUN=false
WORKER_MIN_REPLICAS=1
WORKER_MAX_REPLICAS=8
WORKER_SCALE_UP_QUEUE_DEPTH=100
WORKER_SCALE_DOWN_QUEUE_DEPTH=20
API_MIN_REPLICAS=1
API_MAX_REPLICAS=6
API_SCALE_UP_RPS=50.0
API_SCALE_DOWN_RPS=10.0
